# Copy to .env and fill in. Never commit the real .env.

# SQLite for local dev; Render injects a postgres:// DATABASE_URL in production.
DATABASE_URL=sqlite:///./curastra.db

# Secret used to sign JWTs. Generate a long random string for production.
JWT_SECRET=change-me-in-production

# Where the Active Care Engine runs. Local dev: the uvicorn instance on 8000.
# Production: the engine's public Render URL.
AI_ENGINE_URL=http://localhost:8000

# Shared secret sent to the engine in X-Internal-Key. Must match the engine's
# INTERNAL_API_KEY. Empty works only in local dev (engine auth is open then).
INTERNAL_API_KEY=

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# Web Push (daily reminders). Generate once:
#   python -c "from py_vapid import Vapid02, b64urlencode; from cryptography.hazmat.primitives import serialization; v=Vapid02(); v.generate_keys(); print(b64urlencode(v.private_key.private_numbers().private_value.to_bytes(32,'big'))); print(b64urlencode(v.public_key.public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)))"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Shared secret for the hourly /api/notifications/dispatch call (GitHub Actions).
CRON_SECRET=
